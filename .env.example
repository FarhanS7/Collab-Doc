# =============================================================================
# CollabEditor — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env — it is listed in .gitignore.
# All variables are validated at boot by Zod (see apps/server/src/lib/env.ts)
# =============================================================================

# --- Database ---
POSTGRES_USER=collab_user
POSTGRES_PASSWORD=collab_password
POSTGRES_DB=collabeditor
DATABASE_URL=postgresql://collab_user:collab_password@localhost:5432/collabeditor

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth (NextAuth.js) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-32-char-random-secret-here

# --- OAuth: GitHub ---
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# --- OAuth: Google ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- AI (Anthropic) ---
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
