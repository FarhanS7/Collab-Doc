{
  "name": "@collab/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.integration.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --coverage",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@collab/types": "workspace:*",
    "@prisma/client": "^5.14.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "jose": "^5.3.0",
    "socket.io": "^4.8.3",
    "yjs": "^13.6.31",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@types/qs": "^6.15.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
